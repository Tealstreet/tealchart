//@version=6
strategy("Cash Per Contract Commission", initial_capital=10000, commission_type=strategy.commission.cash_per_contract, commission_value=0.5)
fast = ta.sma(close, 3)
slow = ta.sma(close, 8)
if ta.crossover(fast, slow)
    strategy.entry("Long", strategy.long, qty=3)
if ta.crossunder(fast, slow)
    strategy.close("Long")
plot(strategy.netprofit, title="Net Profit")
