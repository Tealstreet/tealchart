//@version=6
strategy("SMA Crossover", initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.1)
fast = ta.sma(close, 3)
slow = ta.sma(close, 5)
if ta.crossover(fast, slow)
    strategy.entry("Long", strategy.long, qty=1)
if ta.crossunder(fast, slow)
    strategy.close("Long")
plot(fast, title="Fast")
plot(slow, title="Slow")
