{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "jsx": "react-jsx",
    "incremental": false,
    "stripInternal": true
  },
  "exclude": ["**/*.stories.tsx", "**/*.stories.ts", "**/*.stories.mdx", ".storybook/**"]
}
