{
  "name": "@tealstreet/tealchart",
  "version": "0.0.1",
  "private": true,
  "description": "TealChart - Canvas-based OHLCV chart component",
  "scripts": {
    "build": "echo \"Unrequired and disabled when using tsconfig paths aliases, run 'build-force' to test a build.\"",
    "build-force": "tsup",
    "clean": "rimraf ./dist ./coverage ./tsconfig.tsbuildinfo",
    "dev": "echo \"Unrequired and disabled when using tsconfig paths aliases, run 'dev-force' to watch a dev version.\"",
    "dev-force": "tsup --watch",
    "fix-all-files": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs --fix",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs --cache --cache-location ../../.cache/eslint/tealchart.eslintcache",
    "test": "run-s test-unit",
    "test-unit": "vitest run",
    "test-unit-watch": "vitest watch --ui",
    "bench": "vitest bench",
    "typecheck": "tsc --project ./tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@tealstreet/react-colorful": "*",
    "@tealstreet/tealscript": "*",
    "jotai": "^2.17.1",
    "jotai-optics": "^0.4.0",
    "konva": "^10.2.0",
    "optics-ts": "^2.4.1",
    "react-konva": "^19.2.2"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tealstreet/prettierrc": "*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "cross-env": "^7.0.3",
    "eslint": "^10",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^4.0.18"
  }
}
