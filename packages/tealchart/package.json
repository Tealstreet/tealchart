{
  "name": "@tealstreet/tealchart",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "description": "TealChart - Canvas-based OHLCV chart component",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./jailbreak": "./src/jailbreak/index.ts",
    "./native": "./src/index.native.ts",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "echo \"Unrequired and disabled when using tsconfig paths aliases, run 'build-force' to test a build.\"",
    "build-force": "tsup",
    "clean": "rimraf ./dist ./coverage ./tsconfig.tsbuildinfo",
    "dev": "echo \"Unrequired and disabled when using tsconfig paths aliases, run 'dev-force' to watch a dev version.\"",
    "dev-force": "tsup --watch",
    "fix-all-files": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs --fix",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs --cache --cache-location ../../.cache/eslint/tealchart.eslintcache",
    "test": "run-s test-unit",
    "test-unit": "vitest run",
    "test-unit-watch": "vitest watch --ui",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "typecheck:native": "tsc --project ./tsconfig.native.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@nanostores/persistent": "^1.3.4",
    "@nanostores/react": "^1.1.0",
    "@tealstreet/tealscript": "*",
    "jotai": "^2.20.0",
    "jotai-optics": "^0.4.0",
    "konva": "^10.3.0",
    "nanostores": "^1.3.0",
    "optics-ts": "^2.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@napi-rs/canvas": "^1.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "cross-env": "^7.0.3",
    "eslint": "^9.28.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^4.1.8"
  }
}
