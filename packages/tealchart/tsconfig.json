{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "incremental": true,
    "types": ["vitest/globals"],
    "paths": {
      "@tealstreet/tealscript": ["../tealscript/src/index.ts"],
      "@tealstreet/tealscript/src/*": ["../tealscript/src/*"]
    }
  },
  "exclude": [
    "**/node_modules",
    "**/.*/*",
    "dist",
    "src/mobile/**",
    "src/SkiaTealchart.tsx",
    "src/SkiaTealchart.test.tsx",
    "src/index.native.ts",
    "native.ts"
  ],
  "include": [".eslintrc.*", "**/*.ts", "**/*.tsx", "**/*.mts", "**/*.cjs", "**/*.mjs", "**/*.jsx", "**/*.json"]
}
